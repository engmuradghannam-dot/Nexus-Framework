# Copy this file to .env and fill in real values before running the stack.
# Never commit the actual .env file.

# --- Django core ---
# Generate a real one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-real-random-secret-in-production
DEBUG=True
# Comma-separated list of hostnames. Required (no default) when DEBUG=False.
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
DB_NAME=nexus
DB_USER=nexus
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# --- Cache / Celery (Redis) ---
# Leave unset for local dev without Docker — falls back to an in-process
# cache automatically when DEBUG=True. Required in production.
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- CORS ---
# Comma-separated list of frontend origins allowed to call the API.
# Only used when DEBUG=False (DEBUG=True allows all origins for convenience).
CORS_ALLOWED_ORIGINS=https://app.example.com

# --- Email (used by Celery tasks, e.g. notifications) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com
